# ==========================================
# VARIABLES DE ENTORNO - PRODUCCIÓN (VPS)
# ==========================================

# 1. Supabase (Backend/BaaS) — REQUERIDAS
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# 2. n8n Webhooks — REQUERIDAS
# Endpoints de n8n que recibe notificaciones desde el frontend
VITE_N8N_WEBHOOK_QUOTE_URL=https://n8n-farmex.duckdns.org/webhook/quote-request
VITE_N8N_WEBHOOK_PURCHASE_URL=https://n8n-farmex.duckdns.org/webhook/purchase-selection
VITE_N8N_WEBHOOK_CONFIRMATION_URL=https://n8n-farmex.duckdns.org/webhook/quote-confirmation
VITE_N8N_WEBHOOK_BOOKING_URL=https://n8n-farmex.duckdns.org/webhook/booking-finalized

# 3. n8n Autenticación (servidor VPS) — REQUERIDAS
# Credenciales para acceder al panel de n8n en https://n8n-farmex.duckdns.org
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CAMBIA_ESTA_PASSWORD_POR_UNA_SEGURA
