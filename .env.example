# ==========================================
# VARIABLES DE ENTORNO - PRODUCCIÓN (VPS)
# ==========================================

# 1. Supabase (Backend/BaaS)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# 2. n8n (Motor de Flujos)
# n8n lee automáticamente las URLs del docker-compose, pero si requieres API keys ponlas aquí.
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=tu_contraseña_segura
